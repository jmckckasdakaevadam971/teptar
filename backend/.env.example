# ── Сервер ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── База данных PostgreSQL ───────────────────────────────
# Вариант 1: единая строка подключения
DATABASE_URL=postgresql://postgres:teptar@localhost:5432/teptar
# Вариант 2 (если не используете DATABASE_URL): по отдельности
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=teptar
# PGDATABASE=teptar

# ── Аутентификация ───────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
