# ── Production .env для docker-compose ───────────────────
# Скопируйте в .env рядом с docker-compose.yml и поменяйте значения.

# База данных
POSTGRES_DB=teptar
POSTGRES_USER=teptar
POSTGRES_PASSWORD=ОБЯЗАТЕЛЬНО_СМЕНИТЕ_надёжный_пароль

# Аутентификация. deploy.sh сгенерирует случайный секрет автоматически.
JWT_SECRET=ОБЯЗАТЕЛЬНО_СМЕНИТЕ_длинный_секрет
JWT_EXPIRES_IN=7d

# ── Домен и HTTPS ────────────────────────────────────────
# Ваш домен без http:// и без www (www настроится автоматически).
DOMAIN=vorhda.ru
# Email для уведомлений Let's Encrypt (истечение сертификата и т.п.).
CERTBOT_EMAIL=07dakaev07@mail.ru
# 1 = тестовый сервер Let's Encrypt (для отладки, без лимитов), 0 = боевой.
CERTBOT_STAGING=0

# CORS: для прода укажите ваш домен (всё ходит через один origin).
CORS_ORIGIN=https://vorhda.ru

# ── Защита от ботов (Cloudflare Turnstile) ────────────────────
# Бесплатные ключи: https://dash.cloudflare.com → Turnstile → Add site.
# Оставьте пустыми — проверка на бота будет отключена (регистрация работает без неё).
# SITE_KEY — публичный (отдаётся браузеру); SECRET — секретный (только сервер).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Данные ───────────────────────────────────────────────
# Загружать демонстрационное древо при ПЕРВОЙ инициализации БД?
# 1 = да (для теста), 0 = нет (чистый старт, наполняете через UI).
SEED_DEMO=0
# Принудительно пересоздать схему (СТИРАЕТ ВСЕ ДАННЫЕ). Держите 0!
FORCE_RESET=0

# ── Масштабирование (использование всех ядер CPU) ────────
# Число процессов backend/frontend. Для 4 vCPU оптимально 2 + 2.
BACKEND_REPLICAS=2
FRONTEND_REPLICAS=2

# ── Порты nginx ──────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
